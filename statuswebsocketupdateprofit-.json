        "n8nApi": {
          "id": "VfIKJBsNihAATKHc",
          "name": "n8n account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const workflowNode = $('Get a workflow version1').item.json;\nconst executions = $input.all().map(i => i.json);\n\nconst now = new Date();\nconst STUCK_THRESHOLD_MS = 10 * 60 * 1000; // 10 minutos\n\n// Clasifica ejecuciones\nconst succeeded = executions.filter(e => e.status === 'success');\nconst failed = executions.filter(e => e.status === 'error');\nconst running = executions.filter(e => e.status === 'running');\n\n// Detecta ejecuciones colgadas (running por más de STUCK_THRESHOLD_MS)\nconst stuckExecutions = running.filter(e => {\n  const started = new Date(e.startedAt);\n  return (now - started) > STUCK_THRESHOLD_MS;\n});\n\n// Última ejecución exitosa\nconst lastSuccess = succeeded.length > 0\n  ? succeeded.sort((a, b) => new Date(b.startedAt) - new Date(a.startedAt))[0]\n  : null;\n\n// Minutos desde el último éxito\nconst minutesSinceLastSuccess = lastSuccess\n  ? Math.round((now - new Date(lastSuccess.startedAt)) / 60000)\n  : null;\n\n// Nivel de alerta\nlet alertLevel = 'ok';\nif (!workflowNode.active) {\n  alertLevel = 'critical';\n} else if (stuckExecutions.length > 0) {\n  alertLevel = 'critical';\n} else if (failed.length > succeeded.length) {\n  alertLevel = 'warning';\n} else if (minutesSinceLastSuccess !== null && minutesSinceLastSuccess > 30) {\n  alertLevel = 'warning';\n}\n\nreturn [{\n  json: {\n    workflow: workflowNode.name,\n    active: workflowNode.active,\n    alertLevel,\n    successRate: `${succeeded.length}/${executions.length}`,\n    stuckExecutions: stuckExecutions.map(e => ({ id: e.id, startedAt: e.startedAt })),\n    hasStuckExecution: stuckExecutions.length > 0,\n    lastSuccessAt: lastSuccess ? lastSuccess.startedAt : null,\n    minutesSinceLastSuccess,\n    recentExecutions: executions.map(e => ({\n      id: e.id,\n      status: e.status,\n      startedAt: e.startedAt,\n      finished: e.finished\n    }))\n  }\n}];"
      },
