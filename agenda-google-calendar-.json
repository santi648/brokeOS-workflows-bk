        "message": "={{ \"<h2>Cita Confirmada</h2><p>Hola \" + $json.nombre + \", tu cita fue agendada correctamente.</p><p>Servicio: \" + $json.servicio + \"</p><p>Fecha: \" + $json.fecha_inicio + \"</p>\" }}"
      },
