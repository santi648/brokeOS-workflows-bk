      "typeVersion": 2.3,
      "position": [
        672,
        96
      ],
      "parameters": {
        "conditions": {
          "combinator": "and",
          "conditions": [
            {
              "leftValue": "={{ $items(\"Buscar Eventos\").length }}",
              "operator": {
                "type": "number",
                "operation": "equal"
              },
              "rightValue": 0
            }
          ],
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          }
        }
      }
    },
    {
      "id": "e6d1f49d-7568-432c-a255-f09f6ffc7235",
      "name": "Crear Evento",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [
        896,
        0
      ],
      "parameters": {
        "resource": "event",
        "operation": "create",
        "calendar": {
          "__rl": true,
          "mode": "id",
          "value": "primary"
        },
        "start": "={{ $json.fecha_inicio }}",
        "end": "={{ $json.fecha_fin }}",
        "useDefaultReminders": true,
        "additionalFields": {
          "summary": "={{ \"Cita - \" + $json.nombre }}",
          "description": "={{ \"Servicio: \" + $json.servicio + \" | Cliente: \" + $json.nombre }}",
          "attendees": "={{ $json.email }}",
          "sendUpdates": "all",
          "conferenceDataUi": {
            "conferenceDataValues": {
              "conferenceSolution": "hangoutsMeet"
            }
          }
        }
      }
    },
    {
