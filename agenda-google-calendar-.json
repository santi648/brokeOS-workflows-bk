      "typeVersion": 3.4,
      "position": [
        224,
        96
      ],
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {
              "id": "1",
              "name": "fecha_inicio",
              "value": "={{ $json.body.fecha + \"T\" + $json.body.hora + \":00\" }}",
              "type": "string"
            },
            {
              "id": "2",
              "name": "fecha_fin",
              "value": "={{ DateTime.fromISO($json.body.fecha + \"T\" + $json.body.hora + \":00\").plus({ hours: 1 }).toISO() }}",
              "type": "string"
            },
            {
              "id": "3",
              "name": "nombre",
              "value": "={{ $json.body.nombre }}",
              "type": "string"
            },
            {
              "id": "4",
              "name": "email",
              "value": "={{ $json.body.email }}",
              "type": "string"
            },
            {
              "id": "5",
              "name": "servicio",
              "value": "={{ $json.body.servicio }}",
              "type": "string"
            }
          ]
        },
        "includeOtherFields": true
      }
    },
    {
      "id": "2a99c2e0-9ffa-4020-b67d-ed5b160003c2",
      "name": "Buscar Eventos",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [
        448,
        96
      ],
      "parameters": {
        "resource": "event",
        "operation": "getAll",
        "calendar": {
          "__rl": true,
          "mode": "id",
          "value": "primary"
        },
        "returnAll": true,
        "timeMin": "={{ $json.fecha_inicio }}",
        "timeMax": "={{ $json.fecha_fin }}"
      }
    },
    {
