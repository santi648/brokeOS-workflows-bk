    {
      "parameters": {
        "jsCode": "const login = $('Filtrar Cuentas y Símbolos').item.json.login;\nconst name  = $('Filtrar Cuentas y Símbolos').item.json.name;\nconst posicionesActuales = $('Filtrar Cuentas y Símbolos').item.json.positions;\n\nlet posicionesPrevias = [];\ntry {\n  const raw = $json.posicionesPrevias;\n  if (raw) posicionesPrevias = JSON.parse(raw);\n} catch(e) {\n  posicionesPrevias = [];\n}\n\nconst setActuales = new Set(posicionesActuales.map(p => p.ticket));\nconst setPrevios  = new Set(posicionesPrevias.map(p => p.ticket));\n\nconst eventos = [];\n\nfor (const pos of posicionesActuales) {\n  if (!setPrevios.has(pos.ticket)) {\n    eventos.push({\n      login,\n      name,\n      event: 'open',\n      ticket: pos.ticket,\n      symbol: pos.symbol,\n      volume: pos.volume,\n      direction: pos.action\n    });\n  }\n}\n\nfor (const pos of posicionesPrevias) {\n  if (!setActuales.has(pos.ticket)) {\n    eventos.push({\n      login,\n      name,\n      event: 'close',\n      ticket: pos.ticket,\n      symbol: pos.symbol,\n      volume: pos.volume,\n      direction: pos.action\n    });\n  }\n}\n\nreturn [{ json: { login, name, posicionesActuales, eventos } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
