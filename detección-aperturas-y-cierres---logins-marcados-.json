    {
      "parameters": {
        "jsCode": "const accounts = $(\"Switch evento\").first().json.message.accounts;\nconst raw = $('Leer Logins Marcados').first().json.propertyName;\nconst listaLogins = JSON.parse(raw);\nconst listaLoginsStr = listaLogins.map(l => String(l));\n\nconst symbolsAllowed = [\n  \"BearX1000.\",\"BearX400.\",\"BearX500.\",\"BearX777.\",\"BearX900.\",\n  \"BullX1000.\",\"BullX400.\",\"BullX500.\",\"BullX777.\",\"BullX900.\",\n  \"EmasVol10\",\"EmasVol100\",\"EmasVol20\",\"EmasVol30\",\"EmasVol40\",\n  \"EmasVol50\",\"EmasVol60\",\"EmasVol70\",\"EmasVol80\",\"EmasVol90\",\n  \"FomoX111.\",\"FomoX333.\",\"FomoX555.\",\"FomoX888.\",\"FomoX999.\",\n  \"FomoXpeed100.\",\"Fortune100.\",\"Fortune1000.\",\"Fortune250.\",\n  \"Fortune500.\",\"FortuneX200.\",\"FortuneX300.\",\"FortuneX500.\",\n  \"LionX100\",\"LionX120\",\"LionX150\",\"LionX200\",\"LionX25\",\n  \"LionX40\",\"LionX50\",\"LionX60\",\"LionX75\",\"LionX90\",\n  \"VorteX100.\",\"VorteX20.\",\"VorteX40.\",\"VorteX60.\",\"VorteX80.\",\n  \"XpeedDown200\",\"XpeedDown300\",\"XpeedUp200\",\"XpeedUp300\"\n];\n\nconst cuentasFiltradas = accounts.filter(account =>\n  listaLoginsStr.includes(String(account.login))\n);\n\nconst resultado = listaLoginsStr\n  .map(loginStr => {\n    const cuenta = cuentasFiltradas.find(a => String(a.login) === loginStr);\n    if (!cuenta) return null;\n    return {\n      login: cuenta.login,\n      name: cuenta.name,\n      positions: (cuenta.positions ?? [])\n        .filter(p => symbolsAllowed.includes(p.symbol))\n        .map(p => ({\n          ticket: p.ticket,\n          symbol: p.symbol,\n          volume: p.volume,\n          action: p.action,\n          time_create: p.time_create\n        }))\n    };\n  })\n  .filter(Boolean);\n\nreturn resultado.map(account => ({ json: account }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        336
      ],
      "id": "ab50713f-9c6a-4a7e-8b09-5c6810b0d91d",
