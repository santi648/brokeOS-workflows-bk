      {
        "parameters": {
          "jsCode": "const data = $('Start').first().json.message_firstItem;\nconst accounts = data.accounts;\n\nconst rawMarcados = $('whiteListProduccion').first().json.propertyName;\nconst listaLogins = JSON.parse(rawMarcados).map(l => String(l));\n\nconst removedLogins = (data.removed_logins ?? []).map(l => String(l));\n\n// Snapshot de Redis — todas las keys pos:login:position_id activas\nconst rawSnapshot = $('Redis_Snapshot3').first().json;\nconst redisKeys = Object.keys(rawSnapshot).filter(k => k.startsWith('pos:'));\n\nconst symbolsAllowed = [\n  \"BearX1000.\",\"BearX400.\",\"BearX500.\",\"BearX777.\",\"BearX900.\",\n  \"BullX1000.\",\"BullX400.\",\"BullX500.\",\"BullX777.\",\"BullX900.\",\n  \"EmasVol10\",\"EmasVol100\",\"EmasVol20\",\"EmasVol30\",\"EmasVol40\",\n  \"EmasVol50\",\"EmasVol60\",\"EmasVol70\",\"EmasVol80\",\"EmasVol90\",\n  \"FomoX111.\",\"FomoX333.\",\"FomoX555.\",\"FomoX888.\",\"FomoX999.\",\n  \"FomoXpeed100.\",\"Fortune100.\",\"Fortune1000.\",\"Fortune250.\",\n  \"Fortune500.\",\"FortuneX200.\",\"FortuneX300.\",\"FortuneX500.\",\n  \"LionX100\",\"LionX120\",\"LionX150\",\"LionX200\",\"LionX25\",\n  \"LionX40\",\"LionX50\",\"LionX60\",\"LionX75\",\"LionX90\",\n  \"VorteX100.\",\"VorteX20.\",\"VorteX40.\",\"VorteX60.\",\"VorteX80.\",\n  \"XpeedDown200\",\"XpeedDown300\",\"XpeedUp200\",\"XpeedUp300\"\n];\n\nconst VENTANA_SEGUNDOS = 15;\nconst ahoraEnSegundos = Math.floor(data.timestamp_msc / 1000);\n\n// ── OPEN ──────────────────────────────────────────────────────────────────────\nconst cuentasMarcadas = accounts\n  .filter(account => listaLogins.includes(String(account.login)))\n  .flatMap(account => {\n    const positionsFiltradas = (account.positions ?? []).filter(position => {\n      const diff = ahoraEnSegundos - position.time_create;\n      return diff >= 0 && diff <= VENTANA_SEGUNDOS && symbolsAllowed.includes(position.symbol);\n    });\n    return positionsFiltradas.map(position => ({\n      json: {\n        login: String(account.login),\n        name: account.name,\n        estado: \"OPEN\",\n        direccion: position.action,\n        position_id: position.ticket,\n        symbol: position.symbol,\n        volume: position.volume,\n        time_create: position.time_create,\n        price: position.price_open\n      }\n    }));\n  });\n\n// ── CLOSE por removed_logins ──────────────────────────────────────────────────\nconst cuentasEliminadas = removedLogins\n  .filter(login => listaLogins.includes(login))\n  .map(login => ({\n    json: { login, estado: \"CLOSE\" }\n  }));\n\n// ── CLOSE parcial — posición desapareció del WS pero login sigue activo ───────\n// Set de todas las posiciones activas en este mensaje: \"pos:login:position_id\"\nconst posicionesActivasEnWS = new Set(\n  accounts\n    .filter(account => listaLogins.includes(String(account.login)))\n    .flatMap(account =>\n      (account.positions ?? []).map(p =>\n        \"pos:\" + String(account.login) + \":\" + String(p.ticket)\n      )\n    )\n);\n\nconst cierresParciales = redisKeys\n  .filter(key => {\n    const parts = key.split(':');\n    const loginDeKey = parts[1];\n    // El login sigue en el WS (no está en removed_logins)\n    // pero esta posición específica ya no aparece en su array positions\n    const loginSigueEnWS = accounts.some(a => String(a.login) === loginDeKey);\n    const loginEstaEnRemoved = removedLogins.includes(loginDeKey);\n    return loginSigueEnWS && !loginEstaEnRemoved && !posicionesActivasEnWS.has(key);\n  })\n  .map(key => {\n    const parts = key.split(':');\n    const loginDeKey = parts[1];\n    return {\n      json: {\n        login: loginDeKey,\n        estado: \"CLOSE\"\n      }\n    };\n  });\n\nreturn [...cuentasMarcadas, ...cuentasEliminadas, ...cierresParciales];"
        },
