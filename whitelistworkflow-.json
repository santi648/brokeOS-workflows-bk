        "jsCode": "// Code_DedupOpen — versión final correcta\nconst redisResult = $input.all(); // array de items, uno por posición\n\nreturn redisResult\n  .map((redisItem, index) => {\n    const propertyName = redisItem.json.propertyName ?? null;\n    \n    // Si ya existe en Redis → duplicado, ignorar este item\n    if (propertyName) return null;\n    \n    // Recuperar el item original del Switch3 por índice\n    const originalItem = $('Switch').all()[index]?.json;\n    if (!originalItem) return null;\n    \n    return { json: { ...originalItem } };\n  })\n  .filter(item => item !== null);"
