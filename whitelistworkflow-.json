    {
      "parameters": {
        "jsCode": "const allBearer = $input.all();\nconst allPrev = $('Code in JavaScript7').all();\n\nreturn allBearer.map((bearerItem, index) => {\n  const bearerToken = bearerItem.json.bearerToken;\n  const prev = allPrev[index]?.json;\n  if (!prev) return null;\n  return {\n    json: {\n      login:      prev.login,\n      unix_stamp: prev.unix_stamp,\n      positions:  prev.positions,  // ← array completo\n      bearerToken\n    }\n  };\n}).filter(Boolean);"
      },
      "type": "n8n-nodes-base.code",
