    {
      "parameters": {
        "jsCode": "const allResponses = $input.all();\nconst allPrev = $('Code in JavaScript8').all();\n\nreturn allResponses.flatMap((responseItem, index) => {\n  const orders = responseItem.json.orders ?? [];\n  const prev = allPrev[index]?.json;\n  if (!prev) return [];\n\n  const { login, positions } = prev;\n\n  return positions.flatMap(pos => {\n    const order = orders.find(o => String(o.position_id) === String(pos.position_id));\n\n    if (!order) return [];\n    if (order.time_close === 0 || order.time_close === null) return [];\n\n    return [{\n      json: {\n        login,\n        position_id:   String(pos.position_id),\n        symbol:        order.deal_internal_out?.symbol ?? order.symbol ?? pos.symbol,\n        volume:        order.deal_internal_out?.lots ?? order.lots,\n        estado_cierre: \"CONFIRMADO\",\n        key:           pos.key\n      }\n    }];\n  });\n});"
      },
