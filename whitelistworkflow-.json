      {
        "parameters": {
          "jsCode": "// Recibe TODOS los items CLOSE del Switch de una vez\nconst closeItems = $input.all();\nconst rawSnapshot = $('Redis_Snapshot3').first().json;\n\nconst byLogin = {};\n\nfor (const item of closeItems) {\n  const loginCierre = String(item.json.login);\n\n  for (const [key, rawValue] of Object.entries(rawSnapshot)) {\n    if (!key.startsWith('pos:')) continue;\n    const parts = key.split(':');\n    if (parts[1] !== loginCierre) continue;\n\n    const redisData = JSON.parse(rawValue);\n\n    if (!byLogin[loginCierre]) {\n      byLogin[loginCierre] = {\n        login: loginCierre,\n        unix_stamp: redisData.unix_stamp,\n        positions: []\n      };\n    } else if (redisData.unix_stamp < byLogin[loginCierre].unix_stamp) {\n      byLogin[loginCierre].unix_stamp = redisData.unix_stamp;\n    }\n\n    byLogin[loginCierre].positions.push({\n      key,\n      position_id: String(redisData.position_id),\n      symbol: redisData.symbol\n    });\n  }\n}\n\nreturn Object.values(byLogin).map(entry => ({ json: entry }));"
        },
